FROM busybox:1.37
RUN addgroup -g 10001 demo && adduser -D -u 10001 -G demo demo && mkdir -p /state /workspace/projects
COPY demo/configs/rdsocial.baseline.json /state/rdsocial.json
COPY demo/configs/engageflow.baseline.json /state/engageflow.json
COPY demo/projects /workspace/projects
RUN chown -R 10001:10001 /state /workspace
USER 10001:10001
CMD ["true"]

